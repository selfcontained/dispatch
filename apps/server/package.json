    "@fastify/websocket": "^8.3.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "fastify": "^4.29.1",
    "node-pty": "1.0.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.10.0",
    "@types/pg": "^8.18.0",
