HOST=0.0.0.0
DISPATCH_PORT=6767
DATABASE_URL=postgres://dispatch:dispatch@127.0.0.1:5432/dispatch
AUTH_TOKEN=change-me
MEDIA_ROOT=~/.dispatch/media
DISPATCH_AGENT_RUNTIME=inert
# TLS_CERT=~/.dispatch/tls/cert.pem
# TLS_KEY=~/.dispatch/tls/key.pem

# These settings are for the production server. For local development,
# use bin/dispatch-dev which auto-selects free ports and creates an
# isolated database — no manual configuration needed.
