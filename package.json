{
  "name": "dispatch",
  "version": "0.2.18",
  "private": true,
  "description": "Local-first control plane for remote Codex CLI agents with simulator media",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run build:web && tsc -p tsconfig.json",
    "build:web": "npm --prefix web run build",
    "check:web": "npm --prefix web run check",
    "lint:web": "npm --prefix web run lint",
    "finalize:web": "npm run check:web && npm run build:web",
    "start": "node dist/server.js",
    "release": "bin/dispatch-server update",
    "db:migrate": "tsx src/db/migrate.ts",
    "check": "tsc --noEmit && npm run check:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bash scripts/e2e-isolated.sh"
  },
  "dependencies": {
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^6.12.0",
    "@fastify/websocket": "^8.3.1",
    "dotenv": "^17.3.1",
    "fastify": "^4.29.1",
    "node-pty": "^1.0.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.0",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "playwright": "^1.54.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
