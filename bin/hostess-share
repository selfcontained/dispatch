#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  hostess-share <image-path> [name]
  hostess-share --sim [udid] [name]

Examples:
  hostess-share ./artifacts/homepage.png
  hostess-share ./artifacts/homepage.png playwright-home.png
  hostess-share --sim
  hostess-share --sim booted ios-home.png
USAGE
}

DEST_DIR="${HOSTESS_MEDIA_DIR:-${HOSTESS_MDEIA_DIR:-}}"
if [[ -z "$DEST_DIR" ]]; then
  echo "hostess-share: HOSTESS_MEDIA_DIR is not set (HOSTESS_MDEIA_DIR fallback also empty)." >&2
  exit 2
fi

mkdir -p "$DEST_DIR"

timestamp="$(date +%Y%m%d-%H%M%S)"

SOURCE_PATH=""
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || "${1:-}" == "" ]]; then
  usage
  exit 0
fi

if [[ "${1:-}" == "--sim" ]]; then
  udid="${2:-booted}"
  out_name="${3:-sim-${timestamp}.png}"
  tmp="${TMPDIR:-/tmp}/${out_name}"
  xcrun simctl io "$udid" screenshot --type=png "$tmp" >/dev/null
  SOURCE_PATH="$tmp"
else
  SOURCE_PATH="$1"
fi

if [[ ! -f "$SOURCE_PATH" ]]; then
  echo "hostess-share: source file not found: $SOURCE_PATH" >&2
  exit 3
fi

lower_name="$(basename "$SOURCE_PATH" | tr '[:upper:]' '[:lower:]')"
if [[ ! "$lower_name" =~ \.(png|jpg|jpeg|gif|webp)$ ]]; then
  echo "hostess-share: unsupported file type. Use png/jpg/jpeg/gif/webp." >&2
  exit 4
fi

if [[ "${1:-}" == "--sim" ]]; then
  preferred_name="${3:-$(basename "$SOURCE_PATH")}" 
else
  preferred_name="${2:-$(basename "$SOURCE_PATH")}" 
fi

safe_name="$(echo "$preferred_name" | tr ' ' '-' | tr -cd '[:alnum:]._-')"
if [[ -z "$safe_name" ]]; then
  safe_name="shared-${timestamp}.png"
fi

ext="${safe_name##*.}"
base="${safe_name%.*}"
dest_file="${DEST_DIR}/${base}-${timestamp}.${ext}"
cp "$SOURCE_PATH" "$dest_file"

echo "$dest_file"
