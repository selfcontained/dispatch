#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  dispatch-share <image-path> [name]
  dispatch-share --sim [udid] [name]

Examples:
  dispatch-share ./artifacts/homepage.png
  dispatch-share ./artifacts/homepage.png playwright-home.png
  dispatch-share --sim
  dispatch-share --sim booted ios-home.png
USAGE
}

API_BASE="${DISPATCH_API_BASE:-http://127.0.0.1:${DISPATCH_PORT:-8787}}"
AGENT_ID="${DISPATCH_AGENT_ID:-}"

if [[ -z "$AGENT_ID" ]]; then
  echo "dispatch-share: DISPATCH_AGENT_ID is not set." >&2
  exit 2
fi

timestamp="$(date +%Y%m%d-%H%M%S)"

SOURCE_PATH=""
SOURCE_TYPE="screenshot"
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || "${1:-}" == "" ]]; then
  usage
  exit 0
fi

if [[ "${1:-}" == "--sim" ]]; then
  udid="${2:-booted}"
  out_name="${3:-sim-${timestamp}.png}"
  tmp="${TMPDIR:-/tmp}/${out_name}"
  xcrun simctl io "$udid" screenshot --type=png "$tmp" >/dev/null
  SOURCE_PATH="$tmp"
  SOURCE_TYPE="simulator"
else
  SOURCE_PATH="$1"
fi

if [[ ! -f "$SOURCE_PATH" ]]; then
  echo "dispatch-share: source file not found: $SOURCE_PATH" >&2
  exit 3
fi

lower_name="$(basename "$SOURCE_PATH" | tr '[:upper:]' '[:lower:]')"
if [[ ! "$lower_name" =~ \.(png|jpg|jpeg|gif|webp)$ ]]; then
  echo "dispatch-share: unsupported file type. Use png/jpg/jpeg/gif/webp." >&2
  exit 4
fi

if [[ "${1:-}" == "--sim" ]]; then
  preferred_name="${3:-$(basename "$SOURCE_PATH")}"
else
  preferred_name="${2:-$(basename "$SOURCE_PATH")}"
fi

safe_name="$(echo "$preferred_name" | tr ' ' '-' | tr -cd '[:alnum:]._-')"
if [[ -z "$safe_name" ]]; then
  safe_name="shared-${timestamp}.png"
fi

ext="${safe_name##*.}"
base="${safe_name%.*}"
upload_name="${base}-${timestamp}.${ext}"

response="$(curl -fsS -X POST \
  -F "file=@${SOURCE_PATH};filename=${upload_name}" \
  -F "source=${SOURCE_TYPE}" \
  "${API_BASE}/api/v1/agents/${AGENT_ID}/media")"

echo "$response"
